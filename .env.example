VITE_BACKEND_URL=http://127.0.0.1:8001

# Keep real API keys on the backend only. Never expose secrets through VITE_*.
GEMINI_API_KEY=
GROQ_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
